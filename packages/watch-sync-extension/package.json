{
  "name": "@fedora-movies/watch-sync-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:test": "WATCH_SYNC_TEST_MANIFEST=1 vite build --outDir dist-test",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:integration": "npm run build:test && playwright test --config playwright.config.ts",
    "fixtures": "node fixtures/server.mjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
