{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["chrome", "vite/client", "vitest/globals"],
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src", "test", "vite.config.ts", "vitest.config.ts", "manifest.config.ts", "manifest.test.config.ts", "playwright.config.ts"]
}
